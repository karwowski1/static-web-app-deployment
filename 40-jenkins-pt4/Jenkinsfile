pipeline {
    agent none

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'prod'], description: 'Environment')
    }

    environment {
        AWS_REGION      = 'eu-central-1'
        ECR_REGISTRY    = '858986858999.dkr.ecr.eu-central-1.amazonaws.com'
        APP_DIR         = 'app'
        TF_APP_DIR      = "terraform/envs/${params.ENVIRONMENT}"
        ECR_REPOSITORY  = "${params.ENVIRONMENT}-task-api"
        IMAGE_TAG       = "${params.ENVIRONMENT}-${BUILD_NUMBER}"
        FULL_IMAGE_NAME = "${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}"
        AWS_CREDENTIALS_ID = 'aws-credentials'
    }

    stages {
        stage('Prepare ECR') {
            agent { label 'infra' }
            steps {
                dir("${TF_APP_DIR}") {
                    sh 'terraform init -input=false'
                    sh "terraform apply -target=module.app_cluster.aws_ecr_repository.app -var='environment=${params.ENVIRONMENT}' -auto-approve"
                }
            }
        }

        stage('Build & Test') {
            agent {
                docker {
                    image 'node:18'
                    label 'ci'
                }
            }
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install'
                    sh 'npm test'
                }
            }
        }

        stage('Push Image') {
            agent { label 'ci' }
            steps {
                script {
                    dir("${APP_DIR}") {
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                        def appImage = docker.build("${FULL_IMAGE_NAME}")
                        appImage.push()
                        appImage.push('latest')
                    }
                }
            }
        }

        stage('Infrastructure Plan') {
            agent { label 'infra' }
            steps {
                dir("${TF_APP_DIR}") {
                    sh 'terraform init -input=false'
                    sh "terraform plan -var='environment=${params.ENVIRONMENT}' -out=tfplan"
                }
            }
        }

        stage('Approval') {
            when { expression { params.ENVIRONMENT == 'prod' } }
            steps {
                input message: "Deploy to PROD?"
            }
        }

        stage('Infrastructure Apply') {
            agent { label 'infra' }
            steps {
                dir("${TF_APP_DIR}") {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Deployment Validation') {
            agent { label 'infra' }
            steps {
                script {
                    dir("${TF_APP_DIR}") {
                        def albDns = sh(script: 'terraform output -raw alb_dns_name', returnStdout: true).trim()
                        sleep 60
                        def status = sh(
                            script: "curl -s -o /dev/null -w '%{http_code}' http://${albDns}/health || echo 'failed'",
                            returnStdout: true
                        ).trim()
                        
                        if (status != "200") {
                            error "Validation failed: ${status}"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            node('ci') {
                sh "docker rmi ${FULL_IMAGE_NAME} || true"
            }
        }
    }
}